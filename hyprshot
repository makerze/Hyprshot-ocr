#!/usr/bin/env bash

set -e

function Help() {
    cat <<EOF
Usage: hyprshot [options ..] [-m [mode] ..] -- [command]

Hyprshot is an utility to easily take screenshot in Hyprland using your mouse.

It allows taking screenshots of windows, regions and monitors which are saved to a folder of your choosing and copied to your clipboard.

Examples:
  capture a window                      \`hyprshot -m window\`
  capture active window to clipboard    \`hyprshot -m window -m active --clipboard-only\`
  capture selected monitor              \`hyprshot -m output -m DP-1\`
  OCR selected region to clipboard      \`hyprshot -m ocr\`

Options:
  -h, --help                show help message
  -m, --mode                one of: output, window, region, ocr, active, OUTPUT_NAME
  -o, --output-folder       directory in which to save screenshot
  -f, --filename            the file name of the resulting screenshot
  --ocr-lang                comma-separated OCR language list; defaults to en
  -l, --label               append a contextual label to the saved filename
  -D, --delay               how long to delay taking the screenshot after selection (seconds)
  -z, --freeze              freeze the screen on initialization
  -d, --debug               print debug information
  -s, --silent              don't send notification when screenshot is saved
  -r, --raw                 output raw image data to stdout
  -t, --notif-timeout       notification timeout in milliseconds (default 5000)
  --clipboard-only          copy screenshot to clipboard and don't save image in disk
  -- [command]              open screenshot with a command of your choosing. e.g. hyprshot -m window -- mirage

Modes:
  output        take screenshot of an entire monitor
  window        take screenshot of an open window
  region        take screenshot of selected region
  ocr           OCR selected region and copy extracted text to clipboard
  active        take screenshot of active window|output
                (you must use --mode again with the intended selection)
  OUTPUT_NAME   take screenshot of output with OUTPUT_NAME
                (you must use --mode again with the intended selection)
                (you can get this from \`hyprctl monitors\`)
EOF
}

function Print() {
    if [ $DEBUG -eq 0 ]; then
        return 0
    fi
    
    1>&2 printf "$@" 
}

function send_notification() {
    if [ $SILENT -eq 1 ]; then
        return 0
    fi

    local message=$([ $CLIPBOARD -eq 1 ] && \
        echo "Image copied to the clipboard" || \
        echo "Image saved in <i>${1}</i> and copied to the clipboard.")
    notify-send "Screenshot saved" \
                "${message}" \
                -t "$NOTIF_TIMEOUT" -i "${1}" -a Hyprshot
}

function send_ocr_notification() {
    if [ $SILENT -eq 1 ]; then
        return 0
    fi

    notify-send "OCR complete" \
                "Extracted text copied to the clipboard." \
                -t "$NOTIF_TIMEOUT" -a Hyprshot
}

function cleanup_freeze() {
    if [ -n "${HYPRPICKER_PID:-}" ] && kill -0 "$HYPRPICKER_PID" >/dev/null 2>&1; then
        kill "$HYPRPICKER_PID" >/dev/null 2>&1 || true
        sleep 0.1
        if kill -0 "$HYPRPICKER_PID" >/dev/null 2>&1; then
            kill -9 "$HYPRPICKER_PID" >/dev/null 2>&1 || true
        fi
        wait "$HYPRPICKER_PID" 2>/dev/null || true
    fi
    HYPRPICKER_PID=""
}

function geometry_fields() {
    local geometry="${1}"
    local xy_str=$(echo "${geometry}" | cut -d' ' -f1)
    local wh_str=$(echo "${geometry}" | cut -d' ' -f2)
    local x=$(echo "${xy_str}" | cut -d',' -f1)
    local y=$(echo "${xy_str}" | cut -d',' -f2)
    local width=$(echo "${wh_str}" | cut -dx -f1)
    local height=$(echo "${wh_str}" | cut -dx -f2)
    printf "%s %s %s %s\n" "$x" "$y" "$width" "$height"
}

function sanitize_label() {
    local label="${1}"
    label=$(printf "%s" "$label" | tr '[:upper:]' '[:lower:]')
    label=$(printf "%s" "$label" | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_+/_/g')
    label=$(printf "%.40s" "$label")
    label=$(printf "%s" "$label" | sed -E 's/_+$//')
    printf "%s" "$label"
}

function title_label() {
    local title="${1}"
    local class_name="${2}"
    local label=$(sanitize_label "$title")

    if [ -z "$label" ]; then
        label=$(sanitize_label "$class_name")
    fi

    printf "%s" "$label"
}

function center_point_for_geometry() {
    local geometry="${1}"
    read -r x y width height <<< "$(geometry_fields "$geometry")"
    printf "%s %s\n" "$((x + width / 2))" "$((y + height / 2))"
}

function monitor_for_geometry() {
    local geometry="${1}"
    read -r point_x point_y <<< "$(center_point_for_geometry "$geometry")"

    hyprctl -j monitors | jq -c \
        --argjson point_x "$point_x" \
        --argjson point_y "$point_y" '
        first(
            .[] |
            select(
                .x <= $point_x and
                .y <= $point_y and
                (
                    .x +
                    (
                        if (.transform % 2 == 0) then
                            (.width / .scale | round)
                        else
                            (.height / .scale | round)
                        end
                    )
                ) > $point_x and
                (
                    .y +
                    (
                        if (.transform % 2 == 0) then
                            (.height / .scale | round)
                        else
                            (.width / .scale | round)
                        end
                    )
                ) > $point_y
            )
        ) // empty
    '
}

function workspace_id_for_geometry() {
    local geometry="${1}"
    local monitor="$(monitor_for_geometry "$geometry")"

    if [ -z "$monitor" ]; then
        printf "%s" ""
        return 0
    fi

    printf '%s\n' "$monitor" | jq -r '.activeWorkspace.id // empty'
}

function classes_label_for_geometry() {
    local geometry="${1}"
    local workspace_id="${2}"
    read -r x y width height <<< "$(geometry_fields "$geometry")"

    local classes="$(hyprctl -j clients | jq -r \
        --arg workspace_id "$workspace_id" \
        --argjson x "$x" \
        --argjson y "$y" \
        --argjson width "$width" \
        --argjson height "$height" '
        [
            .[] |
            select(
                (.workspace.id | tostring) == $workspace_id and
                (
                    [0, ([.at[0] + .size[0], $x + $width] | min) - ([.at[0], $x] | max)] | max
                ) * (
                    [0, ([.at[1] + .size[1], $y + $height] | min) - ([.at[1], $y] | max)] | max
                ) > 0
            ) |
            .class // empty
        ] |
        map(select(length > 0)) |
        unique |
        join("_")
    ')"

    sanitize_label "$classes"
}

function find_client_for_geometry() {
    local geometry="${1}"
    local workspace_id="${2}"
    read -r x y width height <<< "$(geometry_fields "$geometry")"
    local center_x=$((x + width / 2))
    local center_y=$((y + height / 2))

    hyprctl -j clients | jq -c \
        --arg workspace_id "$workspace_id" \
        --argjson x "$x" \
        --argjson y "$y" \
        --argjson width "$width" \
        --argjson height "$height" \
        --argjson center_x "$center_x" \
        --argjson center_y "$center_y" '
        map(
            select((.workspace.id | tostring) == $workspace_id) |
            . + {
                contains_center: (
                    .at[0] <= $center_x and
                    .at[1] <= $center_y and
                    (.at[0] + .size[0]) >= $center_x and
                    (.at[1] + .size[1]) >= $center_y
                ),
                overlap_area: (
                    [0, ([.at[0] + .size[0], $x + $width] | min) - ([.at[0], $x] | max)] | max
                ) * (
                    [0, ([.at[1] + .size[1], $y + $height] | min) - ([.at[1], $y] | max)] | max
                )
            }
        )
        | map(select(.overlap_area > 0))
        | sort_by(.contains_center, .overlap_area)
        | last // empty
    '
}

function label_for_output_geometry() {
    local geometry="${1}"
    local workspace_id="$(workspace_id_for_geometry "$geometry")"
    local classes_label="$(classes_label_for_geometry "$geometry" "$workspace_id")"

    if [ -n "$classes_label" ]; then
        printf "%s" "$classes_label"
        return 0
    fi

    printf "%s" "output"
}

function label_for_geometry() {
    local option="${1}"
    local geometry="${2}"
    local workspace_id="$(workspace_id_for_geometry "$geometry")"
    local label=""

    case "$option" in
        output)
            label="$(label_for_output_geometry "$geometry")"
            ;;
        window | region)
            local client="$(find_client_for_geometry "$geometry" "$workspace_id")"
            if [ -n "$client" ]; then
                label="$(title_label \
                    "$(echo "$client" | jq -r '.title // empty')" \
                    "$(echo "$client" | jq -r '.class // empty')")"
            fi
            ;;
    esac

    printf "%s" "$label"
}

function append_label_to_filename() {
    local filename="${1}"
    local label="${2}"

    if [ -z "$label" ]; then
        printf "%s" "$filename"
        return 0
    fi

    if [[ "$filename" == *.* ]]; then
        local extension=".${filename##*.}"
        local base="${filename%.*}"
        printf "%s_%s%s" "$base" "$label" "$extension"
    else
        printf "%s_%s" "$filename" "$label"
    fi
}

function trim() {
    Print "Geometry: %s\n" "${1}"
    local geometry="${1}"
    local xy_str=$(echo "${geometry}" | cut -d' ' -f1)
    local wh_str=$(echo "${geometry}" | cut -d' ' -f2)
    local x=`echo "${xy_str}" | cut -d',' -f1`
    local y=`echo "${xy_str}" | cut -d',' -f2`
    local width=`echo "${wh_str}" | cut -dx -f1`
    local height=`echo "${wh_str}" | cut -dx -f2`

    local monitors="$(hyprctl -j monitors)"
    local max_width=$(jq -r '[.[] | if (.transform % 2 == 0) then (.x + .width) else (.x + .height) end] | max' <<< "$monitors")
    local max_height=$(jq -r '[.[] | if (.transform % 2 == 0) then (.y + .height) else (.y + .width) end] | max' <<< "$monitors")
    local min_x=$(jq -r '[.[] | .x] | min' <<< "$monitors")
    local min_y=$(jq -r '[.[] | .y] | min' <<< "$monitors")

    local cropped_x=$x
    local cropped_y=$y
    local cropped_width=$width
    local cropped_height=$height

    if ((x + width > max_width)); then
        cropped_width=$((max_width - x))
    fi
    if ((y + height > max_height)); then
        cropped_height=$((max_height - y))
    fi

    if ((x < min_x)); then
        cropped_x="$min_x"
        cropped_width=$((cropped_width + x - min_x))
    fi
    if ((y < min_y)); then
        cropped_y="$min_y"
        cropped_height=$((cropped_height + y - min_y))
    fi

    local cropped=$(printf "%s,%s %sx%s\n" \
        "${cropped_x}" "${cropped_y}" \
        "${cropped_width}" "${cropped_height}")
    Print "Crop: %s\n" "${cropped}"
    printf '%s\n' "$cropped"
}

function save_geometry() {
    local geometry="${1}"
    local output=""

    if [ $RAW -eq 1 ]; then
        grim -g "${geometry}" -
        return 0
    fi

    if [ $CLIPBOARD -eq 0 ]; then
        mkdir -p "$SAVEDIR"
        grim -g "${geometry}" "$SAVE_FULLPATH"
        output="$SAVE_FULLPATH"
        wl-copy --type image/png < "$output"
        [ ${#COMMAND[@]} -eq 0 ] || {
            "${COMMAND[@]}" "$output"
        }
    else
        wl-copy --type image/png < <(grim -g "${geometry}" -)
    fi

    send_notification "$output"
}

function run_ocr() {
    local geometry="${1}"
    local screenshot_path="$(mktemp --suffix=.png)"
    local text_output=""

    cleanup_ocr() {
        rm -f "$screenshot_path"
    }
    trap cleanup_ocr RETURN

    grim -g "${geometry}" "$screenshot_path"

    if ! command -v python3 >/dev/null 2>&1; then
        printf "python3 is required for OCR mode.\n" >&2
        exit 1
    fi

    local ocr_langs="${OCR_LANGS:-${HYPRSHOT_OCR_LANGS:-en}}"

    text_output="$(
        HYPRSHOT_OCR_LANGS="$ocr_langs" python3 - "$screenshot_path" <<'PY'
import os
import sys

try:
    import easyocr
except ImportError:
    print("EasyOCR is not installed. Install the Python easyocr package to use OCR mode.", file=sys.stderr)
    sys.exit(1)

image_path = sys.argv[1]
languages = [lang.strip() for lang in os.environ.get("HYPRSHOT_OCR_LANGS", "en").split(",") if lang.strip()]
reader = easyocr.Reader(languages, verbose=False)
result = reader.readtext(image_path, detail=0, paragraph=True)
text = "\n".join(chunk.strip() for chunk in result if chunk.strip())
sys.stdout.write(text)
PY
    )"

    if [ -z "$text_output" ]; then
        printf "No text detected in selected region.\n" >&2
        exit 1
    fi

    printf "%s" "$text_output" | wl-copy --type text/plain
    printf "%s\n" "$text_output"
    send_ocr_notification
}

function begin_grab() {
    if [ $FREEZE -eq 1 ] && command -v hyprpicker >/dev/null 2>&1; then
        hyprpicker -r -z &
        HYPRPICKER_PID=$!
        sleep 0.2
    fi
    local option=$1
    case $option in
        output)
            if [ $CURRENT -eq 1 ]; then
                local geometry="$(grab_active_output)"
            elif [ -z "$SELECTED_MONITOR" ]; then
                local geometry="$(grab_output)"
            else
                local geometry="$(grab_selected_output "$SELECTED_MONITOR")"
            fi
            ;;
        region)
            local geometry="$(grab_region)"
            ;;
        ocr)
            local geometry="$(grab_region)"
            ;;
        window)
            if [ $CURRENT -eq 1 ]; then
                local geometry="$(grab_active_window)"
            else
                local geometry="$(grab_window)"
            fi
            geometry="$(trim "${geometry}")"
            ;;
    esac
    if [ ${DELAY} -gt 0 ] 2>/dev/null; then
        sleep ${DELAY}
    fi

    if [ $LABEL -eq 1 ] && [ "$option" != "ocr" ]; then
        local label="$(label_for_geometry "$option" "$geometry")"
        if [ -n "$label" ]; then
            SAVE_FULLPATH="$SAVEDIR/$(append_label_to_filename "$FILENAME" "$label")"
            Print "Using labeled filename: %s\n" "$SAVE_FULLPATH"
        fi
    fi

    if [ "$option" = "ocr" ]; then
        run_ocr "${geometry}"
    else
        save_geometry "${geometry}"
    fi
}

function grab_output() {
    slurp -or
}

function grab_active_output() {
    local active_workspace="$(hyprctl -j activeworkspace)"
    local monitors="$(hyprctl -j monitors)"
    local workspace_id
    workspace_id="$(jq -r '.id' <<< "$active_workspace")"
    Print "Monitors: %s\n" "$monitors"
    Print "Active workspace: %s\n" "$active_workspace"
    local current_monitor
    current_monitor="$(jq -c --argjson workspace_id "$workspace_id" 'first(.[] | select(.activeWorkspace.id == $workspace_id))' <<< "$monitors")"
    Print "Current output: %s\n" "$current_monitor"
    jq -r '"\(.x),\(.y) \(.width/.scale|round)x\(.height/.scale|round)"' <<< "$current_monitor"
}

function grab_selected_output() {
    local monitor_name="${1}"
    local monitor
    monitor="$(hyprctl -j monitors | jq -c --arg name "$monitor_name" '.[] | select(.name == $name)')"
    Print "Capturing: %s\n" "$monitor_name"
    jq -r '"\(.x),\(.y) \(.width/.scale|round)x\(.height/.scale|round)"' <<< "$monitor"
}

function grab_region() {
    slurp -d
}

function grab_window() {
    local monitors="$(hyprctl -j monitors)"
    local workspace_ids
    workspace_ids="$(jq -c 'map(.activeWorkspace.id)' <<< "$monitors")"
    local clients
    clients="$(hyprctl -j clients | jq -c --argjson workspace_ids "$workspace_ids" '[.[] | select(.workspace.id as $id | $workspace_ids | index($id))]')"
    Print "Monitors: %s\n" "$monitors"
    Print "Clients: %s\n" "$clients"
    # Generate boxes for each visible window and send that to slurp
    # through stdin
    local boxes
    boxes="$(jq -r '.[] | "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"' <<< "$clients")"
    Print "Boxes:\n%s\n" "$boxes"
    slurp -r <<< "$boxes"
}

function grab_active_window() {
    local active_window="$(hyprctl -j activewindow)"
    local box
    box="$(jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"' <<< "$active_window")"
    Print "Box:\n%s\n" "$box"
    printf '%s\n' "$box"
}

function parse_mode() {
    local mode="${1}"

    case $mode in
        window | region | output | ocr)
            OPTION=$mode
            ;;
        active)
            CURRENT=1
            ;;
        *)
            if hyprctl -j monitors | jq -e --arg name "$mode" '.[] | select(.name == $name)' >/dev/null; then
                SELECTED_MONITOR=$mode
            else
                printf "Unknown mode or monitor: %s\n" "$mode" >&2
                exit 2
            fi
            ;;
    esac
}

function args() {
    local options=$(getopt -o hf:o:m:D:dszrlt: --long help,filename:,output-folder:,mode:,ocr-lang:,delay:,clipboard-only,debug,silent,freeze,raw,label,notif-timeout: -- "$@")
    eval set -- "$options"

    while true; do
        case "$1" in
            -h | --help)
                Help
                exit
                ;;
            -o | --output-folder)
                shift;
                SAVEDIR=$1
                ;;
            -f | --filename)
                shift;
                FILENAME=$1
                ;;
            --ocr-lang)
                shift;
                OCR_LANGS=$1
                ;;
            -D | --delay)
		shift;
                DELAY=$1
                ;;
            -m | --mode)
                shift;
                parse_mode "$1"
                ;;
            --clipboard-only)
                CLIPBOARD=1
                ;;
            -d | --debug)
                DEBUG=1
                ;;
            -z | --freeze)
                FREEZE=1
                ;;
            -s | --silent)
                SILENT=1
                ;;
            -r | --raw)
                RAW=1
                ;;
            -l | --label)
                LABEL=1
                ;;
            -t | --notif-timeout)
                shift;
                NOTIF_TIMEOUT=$1
                ;;
            --)
                shift # Skip -- argument
                COMMAND=("$@")
                break;;
        esac
        shift
    done

    if [ -z "$OPTION" ]; then
        Print "A mode is required\n\nAvailable modes are:\n\toutput\n\tregion\n\twindow\n\tocr\n"
        exit 2
    fi
}

if [ -z "$1" ]; then
    Help
    exit
fi

CLIPBOARD=0
DEBUG=0
SILENT=0
RAW=0
LABEL=0
NOTIF_TIMEOUT=5000
CURRENT=0
FREEZE=0
COMMAND=()
HYPRPICKER_PID=""
OCR_LANGS=""
[ -z "$XDG_PICTURES_DIR" ] && type xdg-user-dir &> /dev/null && XDG_PICTURES_DIR=$(xdg-user-dir PICTURES)
FILENAME="$(date +'%Y-%m-%d-%H%M%S_hyprshot.png')"
[ -z "$HYPRSHOT_DIR" ] && SAVEDIR=${XDG_PICTURES_DIR:=~} || SAVEDIR=${HYPRSHOT_DIR}

args "$@"

SAVE_FULLPATH="$SAVEDIR/$FILENAME"
[ $CLIPBOARD -eq 0 ] && Print "Saving in: %s\n" "$SAVE_FULLPATH"
trap cleanup_freeze EXIT INT TERM
begin_grab "$OPTION"
